generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  clerkId   String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets    Pet[]
  orders  Order[]
}

model Pet {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        PetType   @default(DOG)
  breed       String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  photos  PetPhoto[]
  orders  Order[]

  @@index([userId, createdAt])
}

enum PetType {
  DOG
  CAT
  OTHER
}

model PetPhoto {
  id           String   @id @default(cuid())
  petId        String
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  originalUrl  String
  processedUrl String?
  originalKey  String
  processedKey String?
  mimeType     String
  width        Int?
  height       Int?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([petId, createdAt])
}

model Order {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId           String
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  packageType     PackageType
  status          OrderStatus  @default(PENDING)
  amount          Int
  stripePaymentId String?
  stripeSessionId String?
  petName         String
  petMemorialText String?
  promoCode       String?
  discountAmount  Int          @default(0)
  isGift          Boolean      @default(false)
  recipientName   String?
  recipientEmail  String?
  personalMessage String?
  giftToken       String?      @unique
  giftViewedAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  portraits Portrait[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum PackageType {
  SINGLE
  MEMORIAL
  PREMIUM
}

enum OrderStatus {
  PENDING
  PAID
  GENERATING
  COMPLETED
  FAILED
}

model Portrait {
  id             String         @id @default(cuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  style          PortraitStyle
  status         PortraitStatus @default(PENDING)
  previewUrl     String?
  fullUrl        String?
  printReadyUrl  String?
  previewKey     String?
  fullKey        String?
  printReadyKey  String?
  resolvedPrompt String?
  failureReason  String?
  retryCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([orderId, createdAt])
  @@index([status, createdAt])
}

enum PortraitStyle {
  WATERCOLOR
  OIL_PAINTING
  RENAISSANCE
  RAINBOW_BRIDGE
  PENCIL_SKETCH
  POP_ART
  STAINED_GLASS
  IMPRESSIONIST
  ANIME
  MINIMALIST
}

enum PortraitStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model PromoCode {
  id           String       @id @default(cuid())
  code         String       @unique
  type         DiscountType
  value        Int
  description  String?
  isActive     Boolean      @default(true)
  maxUses      Int?
  usedCount    Int          @default(0)
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum DiscountType {
  PERCENT
  FIXED
}
