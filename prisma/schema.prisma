generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  clerkId   String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets         Pet[]
  orders       Order[]
  printOrders  PrintOrder[]
}

model Pet {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  type              PetType   @default(DOG)
  gender            PetGender?
  breed             String?
  description       String?
  personalityTraits String[]  @default([])
  funnyHabits       String?
  favoriteThings    String?
  ownerName         String?
  specialMemory     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  photos  PetPhoto[]
  orders  Order[]

  @@index([userId, createdAt])
}

enum PetType {
  DOG
  CAT
  OTHER
}

enum PetGender {
  MALE
  FEMALE
}

model PetPhoto {
  id           String   @id @default(cuid())
  petId        String
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  originalUrl  String
  processedUrl String?
  originalKey  String
  processedKey String?
  mimeType     String
  width        Int?
  height       Int?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([petId, createdAt])
}

model Order {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId           String
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  packageType     PackageType
  status          OrderStatus  @default(PENDING)
  amount          Int
  portraitCount   Int?
  stripePaymentId String?
  stripeSessionId String?
  petName         String
  petMemorialText String?
  promoCode       String?
  discountAmount  Int          @default(0)
  isGift          Boolean      @default(false)
  recipientName   String?
  recipientEmail  String?
  personalMessage String?
  giftToken       String?      @unique
  giftViewedAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  portraits   Portrait[]
  addOns      OrderAddOn[]
  printOrders PrintOrder[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum PackageType {
  SINGLE
  MEMORIAL
  PREMIUM
  CUSTOM
}

enum OrderStatus {
  PREVIEW
  PREVIEWS_READY
  PENDING
  PAID
  GENERATING
  COMPLETED
  FAILED
}

model Portrait {
  id             String         @id @default(cuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  style          PortraitStyle
  status         PortraitStatus @default(PENDING)
  selected       Boolean        @default(false)
  previewUrl     String?
  fullUrl        String?
  printReadyUrl  String?
  previewKey     String?
  fullKey        String?
  printReadyKey  String?
  resolvedPrompt String?
  failureReason  String?
  retryCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  printOrders PrintOrder[]

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@unique([orderId, style])
}

enum PortraitStyle {
  WATERCOLOR
  OIL_PAINTING
  RENAISSANCE
  RAINBOW_BRIDGE
  PENCIL_SKETCH
  POP_ART
  STAINED_GLASS
  IMPRESSIONIST
  ANIME
  MINIMALIST
  YOUNG_AGAIN
}

enum PortraitStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model PromoCode {
  id           String       @id @default(cuid())
  code         String       @unique
  type         DiscountType
  value        Int
  description  String?
  isActive     Boolean      @default(true)
  maxUses      Int?
  usedCount    Int          @default(0)
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum DiscountType {
  PERCENT
  FIXED
}

enum AddOnType {
  LETTER_FROM_HEAVEN
  STORYBOOK
}

enum AddOnStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model OrderAddOn {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type          AddOnType
  status        AddOnStatus @default(PENDING)
  priceCents    Int
  documentUrl   String?
  documentKey   String?
  videoUrl      String?
  videoKey      String?
  previewUrl    String?
  previewKey    String?
  generatedText String?
  metadata      Json?
  failureReason String?
  retryCount    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([orderId, type])
}

model PrintOrder {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  portraitId        String
  portrait          Portrait         @relation(fields: [portraitId], references: [id], onDelete: Cascade)
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  productType       String           // FRAMED_POSTER, CANVAS, FRAMED_CANVAS
  size              String           // 12x16, 16x20, 24x36
  frameColor        String?          // black, white, natural
  printfulVariantId Int

  status            PrintOrderStatus @default(PENDING)
  printfulOrderId   Int?             @unique
  printfulStatus    String?
  trackingNumber    String?
  trackingUrl       String?
  shippingCarrier   String?

  retailPrice       Int              // cents - what customer pays for product
  shippingCost      Int              @default(0) // cents - shipping charged to customer
  printfulCost      Int              @default(0) // cents - what Printful charges us

  stripeSessionId   String?
  stripePaymentId   String?

  recipientName     String
  recipientAddress1 String
  recipientAddress2 String?
  recipientCity     String
  recipientState    String
  recipientZip      String
  recipientCountry  String           @default("US")
  recipientEmail    String?
  recipientPhone    String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([status])
}

enum PrintOrderStatus {
  PENDING
  PAID
  SUBMITTING
  SUBMITTED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  FAILED
  CANCELED
}
